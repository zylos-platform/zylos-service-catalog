{
  "aliases": {
    "catalog-products": {
      "is_write_index": true
    }
  },
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "1s"
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "productId": {
        "type": "keyword"
      },
      "sellerId": {
        "type": "keyword"
      },
      "name": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "description": {
        "type": "text"
      },
      "categoryId": {
        "type": "keyword"
      },
      "visibility": {
        "type": "keyword"
      },
      "version": {
        "type": "long"
      },
      "attributes": {
        "type": "nested",
        "properties": {
          "name": {
            "type": "keyword"
          },
          "type": {
            "type": "keyword"
          },
          "value": {
            "type": "keyword",
            "fields": {
              "text": {
                "type": "text"
              }
            }
          }
        }
      },
      "variants": {
        "type": "nested",
        "properties": {
          "variantId": {
            "type": "keyword"
          },
          "sku": {
            "type": "keyword"
          },
          "status": {
            "type": "keyword"
          },
          "purchasable": {
            "type": "boolean"
          },
          "listPrice": {
            "properties": {
              "minorUnits": {
                "type": "long"
              },
              "currency": {
                "type": "keyword"
              }
            }
          },
          "attributes": {
            "type": "nested",
            "properties": {
              "name": {
                "type": "keyword"
              },
              "type": {
                "type": "keyword"
              },
              "value": {
                "type": "keyword",
                "fields": {
                  "text": {
                    "type": "text"
                  }
                }
              }
            }
          }
        }
      },
      "occurredAt": {
        "type": "date",
        "format": "epoch_millis"
      },
      "eventId": {
        "type": "keyword"
      }
    }
  }
}
